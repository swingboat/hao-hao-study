# ─────────────────────────────────────────────────────────────────
#  好好学习 v0.1 MVP — 环境变量样例
#
#  使用方式：cp .env.example .env，然后填入真实值。
#  ⚠️ .env 永不入 Git；本文件仅含变量名与本地 docker-compose 的默认值。
# ─────────────────────────────────────────────────────────────────

# ─── 数据库与缓存（本地 docker-compose）───
DATABASE_URL=postgresql://hao:hao_dev@localhost:5432/hao_dev?schema=public
REDIS_URL=redis://localhost:6379

# ─── 对象存储（Cloudflare R2）───
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=hao-hao-uploads
R2_PUBLIC_URL=

# ─── LLM（Webex Proxy，⚠️ 仅运行时读取，禁止入库/入日志/入前端 bundle）───
WEBEX_LLM_TOKEN=

# ─── 鉴权（Auth.js v5）───
AUTH_SECRET=replace_me_with_openssl_rand_base64_32
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# ─── 监控（Sentry）───
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── 域名（前端用，NEXT_PUBLIC_* 会进 bundle，禁止放密钥）───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
