# pnpm 配置 — 信任如下原生依赖运行 postinstall 脚本（避免每次手动 approve）
# 仅放公认的官方包，业务相关脚本仍需明确审阅
auto-install-peers=true
strict-peer-dependencies=false
onlyBuiltDependencies[]=@biomejs/biome
onlyBuiltDependencies[]=@prisma/client
onlyBuiltDependencies[]=@prisma/engines
onlyBuiltDependencies[]=prisma
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=sharp
