# 运营端 .env 示例 — 复制为 .env.local 后填入真实值。
# .env.local 不入 git。

# ─── F1 鉴权 ───────────────────────────────────────────────
# 单管理员账号，PRD §3.1 排他：无注册 / 无找回密码。
ADMIN_USERNAME=admin

# bcrypt hash，生成方式（在 apps/admin/ 下）：
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# ⚠️ 必须把每个 $ 转义为 \$！Next.js 的 @next/env 会展开 $VAR（即便加引号也不豁免），
#    bcrypt hash 形如 $2b$10$… 不转义会被吃成空字符串。
ADMIN_PASSWORD_HASH=\$2b\$10\$replace_me_with_real_bcrypt_hash

# Cookie HMAC 签名用，≥32 字节随机串：
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=replace_me_with_random_32plus_bytes

# ─── F2.2 默认 Provider 绑定（v0.1 env 只读） ─────────────────
# 值为 llm_provider.id（slug）。等总控加 admin_setting 表后改为 UI 可写。
# KP 解析只走 openai_chat + capabilities.vision=true 的 provider。
DEFAULT_PROVIDER_QUESTION=webex-gemini-3.1-pro
DEFAULT_PROVIDER_KNOWLEDGE_POINT=webex-gemini-3.1-pro
DEFAULT_PROVIDER_GOAL_TEMPLATE=webex-gemini-3.1-pro

# ─── 数据库 ────────────────────────────────────────────────
# 与学生端共用同一份 schema（见 docker-compose.yml）。
DATABASE_URL=postgresql://hao:hao@localhost:5432/hao_dev?schema=public

# ─── F3 题集文件 → 试题：@hao/storage 落盘根（仓库外）─────────
# 见 docs/File_Storage_v0.1.md。线上切 S3：STORAGE_DRIVER=s3 + STORAGE_S3_*
STORAGE_DRIVER=fs
STORAGE_FS_ROOT=/Users/huyin/www/hao-hao-study
STORAGE_PUBLIC_BASE_URL=http://localhost:3001
