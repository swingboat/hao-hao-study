{
  "name": "hao-hao-study",
  "version": "0.1.0",
  "private": true,
  "description": "好好学习 — 智能学习助手 v0.1 MVP（monorepo）",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:admin": "pnpm --filter @hao/admin dev",
    "dev:web": "pnpm --filter @hao/web dev",
    "build": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" build",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r --parallel test",
    "db:generate": "pnpm --filter @hao/db generate",
    "db:migrate": "pnpm --filter @hao/db migrate",
    "db:seed": "pnpm --filter @hao/db seed",
    "db:check-textbooks": "pnpm --filter @hao/db exec tsx ../../scripts/check-textbook-scope-integrity.ts",
    "llm:verify-learning-resource": "pnpm --filter @hao/db exec tsx ../../scripts/verify-mixed-learning-material.ts",
    "llm:verify-mixed-material": "pnpm --filter @hao/db exec tsx ../../scripts/verify-mixed-learning-material.ts",
    "db:studio": "pnpm --filter @hao/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3"
  }
}
