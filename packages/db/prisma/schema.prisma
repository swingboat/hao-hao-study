// ══════════════════════════════════════════════════════════════════
//  好好学习 v0.1 MVP — Prisma Schema
// ══════════════════════════════════════════════════════════════════
//  对齐文档：
//    docs/PRD/SmartLearningAssistant_PRD.md      v1.1 §3.3 / §10.4
//    docs/PRD/Operator_Console_MVP_PRD.md        v0.1 §6
//    docs/PRD/Student_Web_MVP_PRD.md             v0.1 §6
//    docs/Tech_Stack_MVP_v0.1.md                 v0.1 §7
//
//  关键决议影响：
//    S1   — knowledge_point_mastery 主键改为 (student_id, kp_id)，无 goal_instance_id
//    S2-A — student.unlocked_kp_ids[] 字段化；spaced_review 每 (student, kp) 一条
//    S2-N — mistake_book_entry 连续 2 次答对自动 resolve
//    C1   — EP 简化；跨 KP 通过 practice_item.kp_ids[] 表达
//    C3   — GOAL_TEMPLATE/INSTANCE 在 v0.1 不入 schema（SQL 硬塞，留待 v0.2）
//
//  命名约定（详见 docs 终稿）：
//    practice_item / practice_attempt          — 题目 / 答题
//    mistake_book_entry                        — 错题本条目（保留中国教育"错题本"概念）
//    knowledge_point_mastery                   — 知识点掌握度
//    spaced_review                             — 间隔复习调度
//    content_upload                            — 内容上传
//    llm_parse_job / llm_parse_staging         — LLM 解析任务 / 待审核结果
// ══════════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// ══════════════════════════════════════════════════════════════════
//  §A  枚举
// ══════════════════════════════════════════════════════════════════

/// 学生学习会话状态
enum LearningSessionStatus {
  in_progress /// 进行中：已凑题，学生答题中
  completed /// 已完成：学生主动提交或番茄钟到期
  abandoned /// 已放弃：超过 25 分钟未提交，下次进入首页时被清扫
}

/// 错题本条目状态（决议 S2 D2=a 永久 resolve，不可 reopen）
enum MistakeStatus {
  open /// 未掌握：等待学生重做或在常规 Session 中召回
  resolved /// 已掌握：连续 2 次答对（决议 S2-N=2）
}

/// 题目类型（v0.1 仅支持选择/填空，决议 Q2=a）
enum PracticeItemType {
  choice /// 选择题（单选/多选）
  fill_in /// 填空题
}

/// LLM Provider 协议类型（运营端 §7）
enum LLMProtocol {
  openai_chat /// OpenAI /v1/chat/completions 协议
  google_generate_content /// Google /v1/models/*:generateContent 协议
}

/// LLM 解析任务种类（运营端 F2.2 默认 Provider 绑定维度）
enum ParseTaskKind {
  practice_item /// 题目抽取
  knowledge_point /// 知识点抽取
  goal_template /// Goal Template 抽取（v0.2 才用，schema 先留位）
}

/// LLM 解析任务状态
enum ParseJobStatus {
  queued /// 已排队，等待 worker 拉取
  running /// 运行中
  succeeded /// 成功
  failed /// 失败：5xx / 超时 / schema 校验未过
}

/// 上传文件类型
enum UploadFileType {
  exam_outline /// 考试大纲（goal_template 用）
  textbook /// 教材 / 章节讲义（knowledge_point 用）
  item_pack /// 题集 / 习题图（practice_item 用）
}

/// 上传记录的处理阶段
enum UploadStatus {
  uploaded /// 已上传，未触发解析
  parsed /// 已触发解析
  published /// 该批次已审核完毕，至少一条 staging 已发布
  discarded /// 全部丢弃
}

/// staging 行的人工审核状态
enum ReviewStatus {
  pending /// 等待审核
  accepted /// 已接受并发布到正式表
  rejected /// 已丢弃
  edited /// 草稿（运营修改了一些字段但尚未发布）
}

/// LearningSession 中题目分配的来源池（用于事后分析；学生端不展示）
enum SessionPoolSource {
  error_review /// 池 A：错题重做
  spaced_repetition /// 池 B：Layer 3 间隔复习
  new_knowledge /// 池 C：新题
}

/// 学段（K-12 全谱系；v0.1 仅 senior，primary/junior 预留 v0.2+）
enum Stage {
  primary /// 小学（grade g1-g6）
  junior /// 初中（grade g7-g9）
  senior /// 高中（grade g10-g12）
}

/// 年级（绝对学龄序号 1-12，跨学段可排序；展示中文标签由 packages/shared/labels/grade 映射）
/// v0.1 学生注册仅允许 g10/g11/g12（高一/高二/高三）；其他取值为 v0.2+ 预留
enum Grade {
  g1 /// 一年级
  g2 /// 二年级
  g3 /// 三年级
  g4 /// 四年级
  g5 /// 五年级
  g6 /// 六年级
  g7 /// 初一（七年级）
  g8 /// 初二（八年级）
  g9 /// 初三（九年级）
  g10 /// 高一
  g11 /// 高二
  g12 /// 高三
}

// ══════════════════════════════════════════════════════════════════
//  §B  主域 — 学生 / 学科 / 知识点 / 题目
// ══════════════════════════════════════════════════════════════════

/// 学科（v0.1 仅 1 条："math" 高中数学），由运营 SQL 硬塞
model subject {
  /// 主键，人类可读字符串。约定使用学科英文标识 + 学段后缀，如 "math_senior"、"math_junior"
  id    String @id
  /// 学科中文名，展示给学生看，如"高中数学"
  name  String
  /// 学段（v0.1 仅 senior）
  stage Stage

  // 反向关系
  knowledge_points          knowledge_point[]
  knowledge_point_masteries knowledge_point_mastery[]
  students_primary          student[]                 @relation("student_primary_subject")

  @@map("subject")
}

/// 学生 — 系统所有学习数据的归属者
model student {
  /// 主键 UUID（系统生成）
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 登录用户名，全局唯一，由运营开户时下发（运营端 F5.2）
  username           String    @unique
  /// argon2 哈希后的密码，明文永不入库
  password_hash      String
  /// 学生真实姓名
  name               String
  /// 学段（v0.1 仅 senior）。冗余存储 = grade 派生（g1-g6→primary / g7-g9→junior / g10-g12→senior），便于范围查询；应用层须保证 stage 与 grade 一致
  stage              Stage
  /// 年级（v0.1 学生注册仅允许 g10/g11/g12 = 高一/高二/高三）；展示用中文标签由 packages/shared/labels/grade 映射
  grade              Grade
  /// 主修学科外键（MVP 仅 math）
  primary_subject_id String
  primary_subject    subject   @relation("student_primary_subject", fields: [primary_subject_id], references: [id])
  /// 目标考试文本标签，如"高考数学 2027"。MVP 仅展示
  target_exam        String
  /// 监护人同意时间。NULL = 学生端 G1.3 尚未确认
  /// 强约束：NULL 时禁止访问任何学习功能（学生端 T2）
  parent_consent_at  DateTime? @db.Timestamptz()
  /// 冷启动期标记。MVP 仅展示，不影响推荐
  cold_start_mode    Boolean   @default(true)
  /// 已解锁知识点 ID 数组（决议 S2-A）
  /// 推荐器三池统一加过滤 kp_id ∈ unlocked_kp_ids（学生端 T3 / T9）
  unlocked_kp_ids    String[]  @db.Uuid
  /// 创建时间（开户时间）
  created_at         DateTime  @default(now()) @db.Timestamptz()
  /// 软删时间。非 NULL 表示已注销（学生端 G5.3 / 运营端 F5.4）
  /// 注销时本表软删，关联 5 张派生表硬删
  soft_deleted_at    DateTime? @db.Timestamptz()

  // 反向关系
  learning_sessions         learning_session[]
  practice_attempts         practice_attempt[]
  knowledge_point_masteries knowledge_point_mastery[]
  mistake_entries           mistake_book_entry[]
  spaced_reviews            spaced_review[]

  @@index([username])
  @@index([soft_deleted_at])
  @@map("student")
}

/// 知识点 — 课程标准最小颗粒度（决议 C1）
model knowledge_point {
  /// 主键 UUID
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 知识点中文名，如"函数的单调性"
  name       String
  /// 所属学科外键
  subject_id String
  subject    subject  @relation(fields: [subject_id], references: [id])
  /// 章节编号文本（v0.1 简化字段，不外键 chapter 实体）
  chapter_no String?
  /// 创建时间
  created_at DateTime @default(now()) @db.Timestamptz()

  // 反向关系
  knowledge_point_masteries knowledge_point_mastery[]
  spaced_reviews            spaced_review[]

  @@unique([subject_id, name])
  @@index([subject_id, chapter_no])
  @@map("knowledge_point")
}

/// 题目（v0.1 仅 choice / fill_in）
model practice_item {
  /// 主键 UUID
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 题干（题目正文）
  content       String
  /// 标准答案
  answer        String
  /// 题目解析全文（学生端 G3.4 展示）
  solution_text String
  /// 关联的所有知识点 ID 数组（决议 C1：N:M 通过数组）
  /// 必须包含 primary_kp_id
  kp_ids        String[]         @db.Uuid
  /// 主知识点 ID（决议 S2-D5：仅主 KP 入错题本）
  primary_kp_id String           @db.Uuid
  /// 难度档：1=最易 ... 5=最难
  difficulty    Int
  /// 题型枚举（决议 Q2=a 不收 essay）
  item_type     PracticeItemType
  /// 创建时间
  created_at    DateTime         @default(now()) @db.Timestamptz()

  // 反向关系
  practice_attempts practice_attempt[]
  mistake_entries   mistake_book_entry[]

  @@index([primary_kp_id])
  @@index([difficulty])
  @@map("practice_item")
}

// ══════════════════════════════════════════════════════════════════
//  §C  学习行为域 — Session / Attempt
// ══════════════════════════════════════════════════════════════════

/// 学习会话（学生端 G3.1）
model learning_session {
  /// 主键 UUID
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 学生外键
  student_id   String                @db.Uuid
  student      student               @relation(fields: [student_id], references: [id])
  /// 开始时间
  started_at   DateTime              @default(now()) @db.Timestamptz()
  /// 结束时间
  ended_at     DateTime?             @db.Timestamptz()
  /// 状态枚举
  status       LearningSessionStatus @default(in_progress)
  /// 本次会话分配的题目 ID 顺序数组（决议 S2-衍生2 去重后）
  /// 长度约束：8 ≤ length ≤ 15
  item_ids     String[]              @db.Uuid
  /// 每道题来自哪个池的标记，与 item_ids 一一对应
  pool_sources SessionPoolSource[]

  // 反向关系
  practice_attempts practice_attempt[]

  @@index([student_id, started_at])
  @@index([status])
  @@map("learning_session")
}

/// 答题记录（学生端 G3.3 提交事务步骤 1）
model practice_attempt {
  /// 主键 UUID
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 所属 Session 外键
  session_id     String           @db.Uuid
  session        learning_session @relation(fields: [session_id], references: [id])
  /// 学生外键（冗余，便于按学生快速查询）
  student_id     String           @db.Uuid
  student        student          @relation(fields: [student_id], references: [id])
  /// 题目外键
  item_id        String           @db.Uuid
  item           practice_item    @relation(fields: [item_id], references: [id])
  /// 学生提交的答案
  student_answer String
  /// 是否答对
  is_correct     Boolean
  /// 答题时间
  answered_at    DateTime         @default(now()) @db.Timestamptz()

  @@index([student_id, answered_at])
  @@index([item_id, is_correct])
  @@map("practice_attempt")
}

// ══════════════════════════════════════════════════════════════════
//  §D  学习状态域 — Mastery / MistakeBookEntry / SpacedReview
// ══════════════════════════════════════════════════════════════════

/// 知识点掌握度（决议 S1：持有者为 (Student × KP)）
model knowledge_point_mastery {
  /// 学生外键（复合主键 part 1）
  student_id         String          @db.Uuid
  student            student         @relation(fields: [student_id], references: [id])
  /// 学科外键（冗余但便于按学科聚合）
  subject_id         String
  subject            subject         @relation(fields: [subject_id], references: [id])
  /// 知识点外键（复合主键 part 2）
  kp_id              String          @db.Uuid
  knowledge_point    knowledge_point @relation(fields: [kp_id], references: [id])
  /// 当前掌握度 [0, 1]
  mastery_score      Float
  /// 历史最高掌握度（决议 Q1=c "曾掌握后回落" UI 文案派生）
  /// mastery_score < 0.2 且 peak_mastery_score >= 0.5 → "需要加强（曾掌握后回落）"
  peak_mastery_score Float           @default(0)
  /// 最近一次答题时间
  last_attempted_at  DateTime?       @db.Timestamptz()

  @@id([student_id, kp_id])
  @@index([student_id, mastery_score])
  @@map("knowledge_point_mastery")
}

/// 错题本条目（Layer 2 — 决议 S2 三层独立）
/// MVP 简化：不分根因类型，N=2 自动 resolve
model mistake_book_entry {
  /// 主键 UUID
  id                        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 学生外键
  student_id                String        @db.Uuid
  student                   student       @relation(fields: [student_id], references: [id])
  /// 题目外键
  item_id                   String        @db.Uuid
  item                      practice_item @relation(fields: [item_id], references: [id])
  /// 状态枚举（决议 D2=a 永久 resolve）
  status                    MistakeStatus @default(open)
  /// 累计答错次数
  error_count               Int           @default(1)
  /// 连续答对次数（决议 S2-N=2：达 2 即转 resolved）
  /// 答错时归零；对其他题的答题不影响
  consecutive_correct_count Int           @default(0)
  /// 创建时间（首次答错该题）
  created_at                DateTime      @default(now()) @db.Timestamptz()
  /// 解决时间。非 NULL 时 status 必为 resolved
  resolved_at               DateTime?     @db.Timestamptz()

  @@unique([student_id, item_id])
  @@index([student_id, status])
  @@map("mistake_book_entry")
}

/// 间隔复习调度（Layer 3 — 决议 S2-衍生3：每 (student, kp) 仅一条）
/// MVP 仅启用触发器 A（答错）+ B（新学），不做 C / D
model spaced_review {
  /// 学生外键（复合主键 part 1）
  student_id      String          @db.Uuid
  student         student         @relation(fields: [student_id], references: [id])
  /// 知识点外键（复合主键 part 2）
  kp_id           String          @db.Uuid
  knowledge_point knowledge_point @relation(fields: [kp_id], references: [id])
  /// 下次到期时间。<= now() 时进入池 B 凑题
  next_review_at  DateTime        @db.Timestamptz()
  /// 艾宾浩斯间隔索引。intervals = [1, 3, 7, 15, 30, 60] 天
  /// 答错重置 idx=0；MVP 不做 idx 推进
  idx             Int             @default(0)
  /// 创建时间
  created_at      DateTime        @default(now()) @db.Timestamptz()
  /// 最近更新
  updated_at      DateTime        @updatedAt @db.Timestamptz()

  @@id([student_id, kp_id])
  @@index([next_review_at])
  @@map("spaced_review")
}

// ══════════════════════════════════════════════════════════════════
//  §E  审计 / 合规域
// ══════════════════════════════════════════════════════════════════

/// 通用审计日志（合规相关动作必落痕）
model audit_log {
  /// 主键 UUID
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 操作发起者 ID
  /// 学生注销 = 学生 UUID 字符串；运营操作 = 管理员 username 字符串
  /// 双角色统一存 text 而非 uuid
  actor_id    String
  /// 受控集合：
  ///   consent_confirmed     — 学生端 G1.3 监护人同意确认
  ///   export_data_self      — 学生端 G5.2 自助导出
  ///   export_data           — 运营端 F5.3 代导出
  ///   delete_self           — 学生端 G5.3 自助注销
  ///   delete_student        — 运营端 F5.4 代注销
  ///   consent_withdraw      — 监护人同意撤回（v0.2+）
  action      String
  /// 目标对象类型（如 "student" / "practice_item"）
  target_type String
  /// 目标对象 ID
  target_id   String
  /// 附加信息（如 IP、User-Agent、删除前快照摘要）
  payload     Json?
  /// 创建时间
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@index([actor_id, created_at])
  @@index([action, created_at])
  @@map("audit_log")
}

// ══════════════════════════════════════════════════════════════════
//  §F  运营 LLM 解析子系统
// ══════════════════════════════════════════════════════════════════

/// LLM Provider 配置
/// MVP 通过 seed 写入：webex-gemini-3.1-pro / webex-gemini-3.5-flash /
/// webex-claude-opus-4.7 / webex-gpt-5.4 / webex-gemini-3-pro-image
///
/// 模型族行为差异（quirks / max_output_tokens / output_normalizers）由 adapter 按
/// 字段值装请求 / 后处理输出，业务层调用方仍然只用 callLLM(providerId, prompt, schema?)，
/// 看不出 Gemini / Claude / GPT 的差别。
model llm_provider {
  /// 主键，运营自定义 slug
  id                 String      @id
  /// 协议类型（决定 callLLM 适配器走哪条分支）
  protocol           LLMProtocol
  /// HTTPS 端点完整 URL
  endpoint           String
  /// 真实模型名（透传到 body.model 或 URL path）
  model              String
  /// 能力位图：{ text, vision, pdf, structured_output }
  capabilities       Json
  /// 鉴权 token 来源 env 变量名（仅记录变量名，禁止存值！）
  auth_env_var       String
  /// 默认调用参数 { temperature?, max_tokens?, top_p? ... }
  default_params     Json        @default("{}")
  /// 输出 token 真实可达值。可能远小于模型文档值（例如 Webex proxy 对 Gemini 实测 cap ~2000）。
  /// callLLM 据此决定要不要分批 / 给 prompt 加输出量提示。null = 未知，按模型文档默认值。
  max_output_tokens  Int?
  /// 模型族行为开关。adapter 按这里的值决定 body 怎么写。已知键：
  ///   - supports_temperature       (default true)
  ///   - supports_response_format   (default true)
  ///   - max_tokens_param_name      (default "max_tokens")
  /// 未知键按 default 行为走。新增 quirk 时同步更新 adapter 实现。
  quirks             Json        @default("{}")
  /// 输出后处理 normalizer key 列表。adapter 收到 rawText 后顺序执行。
  /// 已知 key：
  ///   - zh_punct_to_ascii                  全角点号/逗号 → 半角（U+FF0E → U+002E、U+FF0C → U+002C）
  ///   - prefix_chapter_with_section_sign   章节号没有 § 前缀的自动加上
  ///   - normalize_chapter_subsection       子节号 §1-1 / §1_1 → §1.1
  /// 顺序敏感：先半角化再加前缀。
  output_normalizers String[]    @default([])
  /// 是否启用
  enabled            Boolean     @default(true)
  /// 创建时间
  created_at         DateTime    @default(now()) @db.Timestamptz()

  // 反向关系
  llm_parse_jobs llm_parse_job[]

  @@map("llm_provider")
}

/// 内容上传存档（运营端 F3.1 / F4.3）
model content_upload {
  /// 主键 UUID
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 上传者（管理员 username）
  uploader_id   String
  /// 对象存储 URI（Cloudflare R2）
  file_uri      String
  /// 文件类型
  file_type     UploadFileType
  /// 处理目的（与 ParseTaskKind 对应）
  purpose       ParseTaskKind
  /// 处理阶段
  status        UploadStatus   @default(uploaded)
  /// 文件名（展示用）
  original_name String?
  /// 文件大小（字节）
  size_bytes    Int?
  /// 创建时间
  created_at    DateTime       @default(now()) @db.Timestamptz()

  // 反向关系
  llm_parse_jobs     llm_parse_job[]
  llm_parse_stagings llm_parse_staging[]

  @@index([uploader_id, created_at])
  @@map("content_upload")
}

/// LLM 解析任务（运营端 F3.2 / F4.3 / F7.1）
model llm_parse_job {
  /// 主键 UUID
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的上传记录
  upload_id       String         @db.Uuid
  upload          content_upload @relation(fields: [upload_id], references: [id])
  /// 任务种类
  task_kind       ParseTaskKind
  /// 使用的 Provider
  provider_id     String
  provider        llm_provider   @relation(fields: [provider_id], references: [id])
  /// prompt 版本字符串（代码内常量管理）
  prompt_version  String
  /// 任务状态
  status          ParseJobStatus @default(queued)
  /// 实际发出的 body（脱敏后入库；运营端 T9 redactAuthHeaders 强约束）
  request_payload Json?
  /// LLM 原始返回
  raw_response    Json?
  /// 经 schema 校验后的结构化结果
  parsed_output   Json?
  /// Token 使用量 { prompt, completion, total }
  token_usage     Json?
  /// 端到端耗时（毫秒）
  latency_ms      Int?
  /// 估算成本（美元）
  cost_estimate   Decimal?       @db.Decimal(10, 6)
  /// 失败信息
  error_message   String?
  /// 创建时间
  created_at      DateTime       @default(now()) @db.Timestamptz()
  /// 完成时间
  finished_at     DateTime?      @db.Timestamptz()

  // 反向关系
  llm_parse_stagings llm_parse_staging[]

  @@index([upload_id, created_at])
  @@index([provider_id, status])
  @@map("llm_parse_job")
}

/// 解析结果待审核中间层（运营端 F3.3–F3.7 / F4.3）
/// 每抽出一个候选实体（一题 / 一 KP）写一行
model llm_parse_staging {
  /// 主键 UUID
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 触发本条产出的解析任务
  parse_job_id   String         @db.Uuid
  parse_job      llm_parse_job  @relation(fields: [parse_job_id], references: [id])
  /// 冗余 upload_id 便于按上传批次列表
  upload_id      String         @db.Uuid
  upload         content_upload @relation(fields: [upload_id], references: [id])
  /// 实体种类
  entity_kind    ParseTaskKind
  /// LLM 原始抽取字段（只读不改）
  llm_payload    Json
  /// 审核状态
  review_status  ReviewStatus   @default(pending)
  /// 运营修改后的最终值
  /// pending 时 NULL；edited 时存草稿；accepted 时存最终值
  review_payload Json?
  /// 审核者（管理员 username）
  reviewed_by    String?
  /// 审核时间
  reviewed_at    DateTime?      @db.Timestamptz()
  /// accepted 后指向正式表的 ID（practice_item.id 或 knowledge_point.id）
  /// 多态外键，应用层校验一致性；强约束：accepted ⇒ NOT NULL
  published_id   String?        @db.Uuid
  /// 创建时间
  created_at     DateTime       @default(now()) @db.Timestamptz()

  @@index([upload_id, review_status])
  @@index([parse_job_id])
  @@map("llm_parse_staging")
}
